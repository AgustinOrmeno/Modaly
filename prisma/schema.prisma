generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Modelo de Usuario
// Cada usuario tiene email, contraseña hasheada y un rol
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Guardamos el HASH, nunca la contraseña en texto plano
  role      String   @default("user") // "user" o "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
